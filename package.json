{
  "name": "create-claude-config",
  "version": "0.1.0",
  "description": "Interactive CLI to scaffold Claude Code project configuration for any tech stack",
  "bin": {
    "create-claude-config": "./bin/cli.js"
  },
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "claude:index": "cd .claude/mcp-servers/context-server && npm run build && npm run index"
  },
  "keywords": [
    "claude",
    "claude-code",
    "scaffolding",
    "cli",
    "config"
  ],
  "author": "Wagner Junior",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjjunior/create-claude-config.git"
  },
  "bugs": {
    "url": "https://github.com/wjjunior/create-claude-config/issues"
  },
  "homepage": "https://github.com/wjjunior/create-claude-config#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
